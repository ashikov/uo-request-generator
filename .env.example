# Базовые настройки сервера
# HOST=0.0.0.0
# PORT=3000

# Примеры конфигурации:
# Выберите один сценарий и раскомментируйте его обязательные переменные.
# Опциональные переменные включайте только при необходимости.
# Для новых конфигураций указывайте LLM_API_PROTOCOL явно.
# Без него для обратной совместимости используется chat-completions.

# Yandex AI Chat Completions
# Встроенный endpoint: https://ai.api.cloud.yandex.net/v1/chat/completions
# Обязательные переменные:
# LLM_API_PROTOCOL=chat-completions
# LLM_API_KEY=your_yandex_api_key
# LLM_FOLDER_ID=test-folder-id
# Опционально (по умолчанию будет использована модель gpt://<LLM_FOLDER_ID>/yandexgpt/latest):
# LLM_MODEL=gpt://test-folder-id/yandexgpt/latest

# Yandex AI Responses API
# Встроенный endpoint: https://ai.api.cloud.yandex.net/v1/responses
# Обязательные переменные:
# LLM_API_PROTOCOL=responses
# LLM_API_KEY=your_yandex_api_key
# LLM_FOLDER_ID=test-folder-id
# Опционально (по умолчанию будет использована модель gpt://<LLM_FOLDER_ID>/aliceai-llm-flash/latest):
# LLM_MODEL=gpt://test-folder-id/aliceai-llm-flash/latest

# OpenAI-compatible Chat Completions
# Обязательные переменные:
# LLM_API_PROTOCOL=chat-completions
# LLM_API_URL=https://provider.example/v1/chat/completions
# LLM_API_KEY=your_api_key
# LLM_AUTH_SCHEME=Bearer
# LLM_MODEL=provider-model-name

# OpenAI-compatible Responses API
# Обязательные переменные:
# LLM_API_PROTOCOL=responses
# LLM_API_URL=https://provider.example/v1/responses
# LLM_API_KEY=your_api_key
# LLM_AUTH_SCHEME=Bearer
# LLM_MODEL=provider-model-name
