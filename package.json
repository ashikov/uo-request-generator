{
  "name": "uo-request-generator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=26.3.0 <27",
    "pnpm": "11.12.0"
  },
  "scripts": {
    "dev": "pnpm --filter @uo-request-generator/web dev",
    "build": "pnpm --filter @uo-request-generator/core build && pnpm --filter @uo-request-generator/llm build && pnpm --filter @uo-request-generator/web build",
    "start": "pnpm --filter @uo-request-generator/web start",
    "lint": "biome lint .",
    "lint:md": "markdownlint-cli2 && node scripts/check-file-endings.mjs",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "test": "vitest run",
    "check": "pnpm format:check && pnpm lint && pnpm lint:md && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "26.1.1",
    "markdownlint-cli2": "0.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
