{
  "name": "@uo-request-generator/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=../../.env --conditions=development --import tsx --watch src/server.ts",
    "build": "tsc --build --clean tsconfig.build.json && tsc -p tsconfig.build.json",
    "start": "node --env-file-if-exists=../../.env dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@uo-request-generator/core": "workspace:*",
    "@uo-request-generator/llm": "workspace:*",
    "@fastify/static": "10.1.0",
    "fastify": "5.10.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsx": "4.23.1"
  }
}
